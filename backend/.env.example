# Server
PORT=8080
ENV=development

# Database — matches docker-compose.yml (Postgres+PostGIS published on host 5435)
DATABASE_URL=postgres://bakecity:bakecity_dev@localhost:5435/bakecity?sslmode=disable
DB_HOST=localhost
DB_PORT=5435
DB_USER=bakecity
DB_PASSWORD=bakecity_dev
DB_NAME=bakecity

# Redis — matches docker-compose.yml (Redis published on host 6380)
REDIS_URL=redis://localhost:6380

# JWT
JWT_SECRET=your-secret-key-here

# AWS S3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_BUCKET_NAME=bakecity

# PSP Integration
PSP_API_KEY=
PSP_API_SECRET=
PSP_PROVIDER=pesapal

# Firebase
FCM_SERVER_KEY=

# SMS (Africa's Talking)
AT_API_KEY=
AT_USERNAME=

# Admin
ADMIN_EMAIL=admin@bakecity.local

# Rate limiting (requests per minute per client IP; needs Redis — fails open without it)
RATE_LIMIT_PER_MINUTE=120
AUTH_RATE_LIMIT_PER_MINUTE=10
