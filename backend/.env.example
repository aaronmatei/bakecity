# Server
PORT=8080
ENV=development

# Database
DATABASE_URL=postgres://user:password@localhost:5432/bakecity
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=password
DB_NAME=bakecity

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=your-secret-key-here

# AWS S3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_BUCKET_NAME=bakecity

# PSP Integration
PSP_API_KEY=
PSP_API_SECRET=
PSP_PROVIDER=pesapal

# Firebase
FCM_SERVER_KEY=

# SMS (Africa's Talking)
AT_API_KEY=
AT_USERNAME=

# Admin
ADMIN_EMAIL=admin@bakecity.local
