# Repo-root env consumed by docker-compose.yml (variable interpolation).
# Copy to ".env" in this directory and fill in your Cloudflare R2 values.
# When these are blank the API falls back to a no-op stub presigner.
#
#   1. Cloudflare dashboard → R2 → create a bucket (e.g. bakecity-media)
#   2. R2 → Manage API Tokens → create an "Object Read & Write" token,
#      which gives you an Access Key ID and Secret Access Key
#   3. Your endpoint is https://<ACCOUNT_ID>.r2.cloudflarestorage.com

S3_ENDPOINT=https://<ACCOUNT_ID>.r2.cloudflarestorage.com
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=auto
AWS_BUCKET_NAME=bakecity-media
